# Flow Ledger Environment Variables
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control.

# ─── Supabase — Renderer (public, safe to bundle) ─────────────────────────────
# Get from: supabase.com → your project → Settings → API → Project URL / anon key
REACT_APP_SUPABASE_URL=https://vbukazyoifwugevuhavs.supabase.co
REACT_APP_SUPABASE_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZidWthenlvaWZ3dWdldnVoYXZzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxNTY4MjIsImV4cCI6MjA5MTczMjgyMn0.o7ajv6LzDQ9RpcYP0flCan5ae1e-gw3p3X88AvTysKA

# ─── Supabase — Main process (NEVER expose to renderer) ──────────────────────
# Get from: supabase.com → your project → Settings → API → service_role key
# Used exclusively in electron/main.js to validate activation keys server-side.
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE=eyJh...your-service-role-key...

# ─── Google OAuth (for Calendar + Gmail integration) ─────────────────────────
# Get from: console.cloud.google.com → APIs → Credentials
# REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# REACT_APP_GOOGLE_CLIENT_SECRET=your-client-secret
