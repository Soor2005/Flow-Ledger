# Flow Ledger Environment Variables
# Rename this file to .env and fill in your values

# ─── Supabase (optional — app works fully offline without these) ───────────
# Get these from: supabase.com → your project → Settings → API
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_ANON=eyJh...your-anon-key...

# ─── Google OAuth (for future Calendar + Gmail integration) ───────────────
# Get these from: console.cloud.google.com → APIs → Credentials
# REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# REACT_APP_GOOGLE_CLIENT_SECRET=your-client-secret
